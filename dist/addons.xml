<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
<addon id="plugin.video.catalyst" name="Catalyst" version="0.1.0" provider-name="brhynders">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="addon.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.service" library="service.py" start="login"/>
    <extension point="xbmc.addon.metadata">
        <reuselanguageinvoker>true</reuselanguageinvoker>
        <summary lang="en_GB">Catalyst - lightweight movie &amp; TV streaming</summary>
        <description lang="en_GB">A clean, English-only streaming browser built from scratch.</description>
        <platform>all</platform>
        <license>GPL-3.0-or-later</license>
        <assets>
            <icon>resources/icon.png</icon>
        </assets>
    </extension>
</addon>
</addons>
